{% extends 'base.html.twig' %}

{% block title %}PersonajeDisciplina index{% endblock %}

{% block body %}
    <h1>PersonajeDisciplina index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Nivel</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for personaje_disciplina in personaje_disciplinas %}
            <tr>
                <td>{{ personaje_disciplina.id }}</td>
                <td>{{ personaje_disciplina.nivel }}</td>
                <td>
                    <a href="{{ path('app_personaje_disciplina_show', {'id': personaje_disciplina.id}) }}">show</a>
                    <a href="{{ path('app_personaje_disciplina_edit', {'id': personaje_disciplina.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="3">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_personaje_disciplina_new') }}">Create new</a>
{% endblock %}
